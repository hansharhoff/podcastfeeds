# Copy to config/secrets.yaml (git-ignored). Per-domain Cookie headers used
# when fetching articles, so paid posts are retrieved as the logged-in you.
#
# Getting a Substack cookie: log in to the publication in your browser →
# DevTools (F12) → Application/Storage → Cookies → copy the value of
# `substack.sid` for that site's domain.
#
# cookies:
#   "www.noahpinion.blog": "substack.sid=PASTE_VALUE_HERE"
#   "newsletter.example.com": "substack.sid=..."
